async function init() {
  document.getElementById('app').innerHTML = `
    <div class="loading">
      <div class="spinner"></div>
      <p>Loading TTC Loyalty...</p>
    </div>`;

  if (SHEET_URL === 'YOUR_WEB_APP_URL_HERE') {
    document.getElementById('app').innerHTML = `
      <div class="login-wrap">
        <div class="login-card">
          <div class="login-logo"><h1>🌳 TTC Loyalty</h1><p>Setup required</p></div>
          <p style="font-size:13px;color:#455A64;line-height:1.6;">The Google Sheets URL has not been configured yet. Please follow the setup guide to connect this app to your Google Sheet, then replace <strong>YOUR_WEB_APP_URL_HERE</strong> in the code with your Apps Script URL.</p>
        </div>
      </div>`;
    return;
  }

  try {
    if (isAdmin) {
      const res = await api({ action: 'getAll' });
      if (res.success) { members = res.members; renderAdmin(); }
      else { toast('Could not load members: ' + res.error, '#c62828'); }
    } else if (memberParam) {
      const res = await api({ action: 'getMember', id: memberParam });
      if (res.success) { renderMemberView(res.member); }
      else {
        document.getElementById('app').innerHTML = `
          <div class="login-wrap">
            <div class="login-card">
              <div class="login-logo"><h1>🌳 TTC Loyalty</h1><p>Member not found</p></div>
              <p style="font-size:13px;color:#455A64;text-align:center;">We couldn&#39;t find your membership. Please contact The Treehouse Club for help.</p>
            </div>
          </div>`;
      }
    } else {
      document.getElementById('app').innerHTML = `
        <div class="login-wrap">
          <div class="login-card">
            <div class="login-logo"><h1>🌳 The Treehouse Club</h1><p>Loyalty Program</p></div>
            <p style="font-size:13px;color:#455A64;line-height:1.6;text-align:center;">Please use your personal membership link to view your stamp card, or ask a staff member to look you up.</p>
          </div>
        </div>`;
    }
  } catch(e) {
    document.getElementById('app').innerHTML = `
      <div class="login-wrap">
        <div class="login-card">
          <div class="login-logo"><h1>🌳 TTC Loyalty</h1><p>Connection error</p></div>
          <p style="font-size:13px;color:#c62828;text-align:center;">Could not connect to the database. Please check your internet connection and try again.</p>
        </div>
      </div>`;
  }
}

init();
</script>
